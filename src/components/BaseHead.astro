---
// src/components/BaseHead.astro
import '../styles/global.css';
import type { ImageMetadata } from 'astro';
import FallbackImage from '../assets/blog-placeholder-1.jpg'; 
import { SITE_TITLE } from '../consts';

interface Props {
	title: string;
	description: string;
	image?: string | ImageMetadata;
}

// Menggunakan Astro.site jika sudah diatur di astro.config.mjs, jika belum pakai Astro.url
const canonicalURL = new URL(Astro.url.pathname, Astro.site || Astro.url);

const { title, description, image = FallbackImage } = Astro.props;

// Logika penentuan URL gambar untuk Social Media Preview
const socialImageURL = typeof image === 'string' 
	? new URL(image, Astro.url) 
	: new URL(image.src, Astro.url);

// --- STRUCTURED DATA (JSON-LD) ---
// Memberitahu Google secara eksplisit bahwa ini adalah website NGO/Yayasan
const schemaData = {
  "@context": "https://schema.org",
  "@type": "NGO",
  "name": "Difabelzone Indonesia",
  "alternateName": "Difi Foundation",
  "url": Astro.site || "https://difabelzone-indonesia.vercel.app",
  "logo": new URL("/favicon.svg", Astro.url),
  "description": description,
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Yogyakarta",
    "addressCountry": "ID"
  },
  "sameAs": [
    "https://www.instagram.com/difabelzone.id" // Tambahkan link sosmed resmi nanti
  ]
};
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<meta name="generator" content={Astro.generator} />

<!-- Robots & Indexing -->
<link rel="sitemap" href="/sitemap-index.xml" />
<meta name="robots" content="index, follow" />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
<meta name="author" content="Difabelzone Indonesia" />

<!-- Font Performance Optimization -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={socialImageURL} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={socialImageURL} />

<!-- Theme Color untuk Mobile Browser (Chrome Android) -->
<meta name="theme-color" content="#78350f" />

<!-- JSON-LD Structured Data Script -->
<script type="application/ld+json" set:html={JSON.stringify(schemaData)} />