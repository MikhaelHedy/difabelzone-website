---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
---

<header class="fixed top-6 inset-x-0 z-50 px-4">
	<nav class="max-w-5xl mx-auto bg-white/80 backdrop-blur-md border border-white/20 py-2 px-6 rounded-full shadow-xl flex justify-between items-center transition-all duration-300">
		<!-- Brand/Logo -->
		<h2 class="m-0 text-lg md:text-xl font-bold tracking-tighter">
    <a href="/" class="text-amber-900 no-underline flex items-center gap-1 hover:opacity-80 transition-opacity">
        Difabelzone <span class="text-amber-600 font-medium">Indonesia</span>
    </a>
</h2>

		<!-- Internal Links (Desktop Nav) -->
		<div class="hidden md:flex items-center gap-1">
			<a href="#history" class="px-4 py-2 text-sm font-semibold text-gray-600 no-underline hover:text-amber-800 transition-colors">
				Our Journey
			</a>
			<a href="#purpose" class="px-4 py-2 text-sm font-semibold text-gray-600 no-underline hover:text-amber-800 transition-colors">
				The Purpose
			</a>
			<a href="#artistry" class="px-4 py-2 text-sm font-semibold text-gray-600 no-underline hover:text-amber-800 transition-colors">
				Artistry
			</a>
		</div>

		<!-- Action Button -->
		<div class="flex items-center">
			<a href="#connect" class="bg-amber-800 text-white px-6 py-2 rounded-full text-sm font-semibold tracking-wide hover:bg-black transition-all shadow-md no-underline active:scale-95">
				Connect
			</a>
		</div>
	</nav>
</header>

<style>
	header { background: transparent; box-shadow: none; }
</style>