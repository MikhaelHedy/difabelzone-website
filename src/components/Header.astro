---
// src/components/Header.astro
import { Image } from 'astro:assets';
import logoImg from '../assets/logo.png'; // Mengambil dari src/assets/logo.png
---

<header class="fixed top-4 md:top-6 inset-x-0 z-50 px-4 font-sans">
    <nav id="main-nav" class="max-w-5xl mx-auto bg-white/90 backdrop-blur-md border border-white/20 py-2 px-4 md:px-6 rounded-[2rem] md:rounded-full shadow-xl flex justify-between items-center transition-all duration-300">
        
        <!-- Brand/Logo -->
        <a href="/" class="flex items-center hover:opacity-80 transition-opacity">
            <Image 
                src={logoImg} 
                alt="Difabelzone Indonesia Logo" 
                class="h-9 md:h-11 w-auto object-contain"
                loading="eager"
            />
        </a>

        <!-- Desktop Navigation -->
        <div class="hidden md:flex items-center gap-1">
            <a href="#history" class="nav-link px-4 py-2 text-sm font-semibold text-gray-600 no-underline hover:text-amber-800 transition-colors">Our Journey</a>
            <a href="#purpose" class="nav-link px-4 py-2 text-sm font-semibold text-gray-600 no-underline hover:text-amber-800 transition-colors">Purpose</a>
            <a href="#artistry" class="nav-link px-4 py-2 text-sm font-semibold text-gray-600 no-underline hover:text-amber-800 transition-colors">Artistry</a>
        </div>

        <!-- Right Side: CTA + Mobile Toggle -->
        <div class="flex items-center gap-2 md:gap-4">
            <a href="#connect" class="bg-[#78350f] text-white px-5 md:px-6 py-2.5 rounded-full text-[11px] md:text-sm font-bold uppercase tracking-widest hover:bg-black transition-all shadow-md no-underline active:scale-95 whitespace-nowrap">
                Connect
            </a>
            
            <button id="menu-toggle" aria-label="Toggle Menu" class="md:hidden p-2 text-amber-900 focus:outline-none">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                </svg>
            </button>
        </div>
    </nav>

    <!-- Mobile Menu Dropdown -->
    <div id="mobile-menu" class="hidden md:hidden mt-2 mx-auto max-w-[95%] bg-white/95 backdrop-blur-lg border border-gray-100 rounded-2xl shadow-2xl p-4 flex flex-col gap-2 font-sans">
        <a href="#history" class="mobile-link px-4 py-3 text-gray-700 font-bold no-underline border-b border-gray-50">Our Journey</a>
        <a href="#purpose" class="mobile-link px-4 py-3 text-gray-700 font-bold no-underline border-b border-gray-50">The Purpose</a>
        <a href="#artistry" class="mobile-link px-4 py-3 text-gray-700 font-bold no-underline">Artistry</a>
    </div>
</header>

<script>
    const menuToggle = document.getElementById('menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    const menuIcon = document.getElementById('menu-icon');
    const mobileLinks = document.querySelectorAll('.mobile-link');
    const sections = document.querySelectorAll('section[id]');

    if (menuToggle && mobileMenu && menuIcon) {
        menuToggle.addEventListener('click', () => {
            mobileMenu.classList.toggle('hidden');
            const isOpen = !mobileMenu.classList.contains('hidden');
            menuIcon.setAttribute('d', isOpen ? 'M6 18L18 6M6 6l12 12' : 'M4 6h16M4 12h16M4 18h16');
        });

        mobileLinks.forEach(link => {
            link.addEventListener('click', () => {
                mobileMenu.classList.add('hidden');
                menuIcon.setAttribute('d', 'M4 6h16M4 12h16M4 18h16');
            });
        });
    }

    function highlightNav() {
        let scrollY = window.pageYOffset;
        sections.forEach(current => {
            const sectionHeight = (current as HTMLElement).offsetHeight;
            const sectionTop = (current as HTMLElement).offsetTop - 120;
            const sectionId = current.getAttribute('id');
            if (scrollY > sectionTop && scrollY <= sectionTop + sectionHeight) {
                document.querySelector(`.nav-link[href*=${sectionId}]`)?.classList.add('active');
                document.querySelector(`.mobile-link[href*=${sectionId}]`)?.classList.add('active');
            } else {
                document.querySelector(`.nav-link[href*=${sectionId}]`)?.classList.remove('active');
                document.querySelector(`.mobile-link[href*=${sectionId}]`)?.classList.remove('active');
            }
        });
    }
    window.addEventListener('scroll', highlightNav);
</script>

<style>
    header { background: transparent; box-shadow: none; }
    .nav-link.active, .mobile-link.active {
        color: #92400e !important;
        font-weight: 800;
    }
</style>