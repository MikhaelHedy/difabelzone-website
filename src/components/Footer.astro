---
// src/components/Footer.astro
import { Image } from 'astro:assets';
import logoImg from '../assets/logo.png'; // Pastikan file logo ada di folder assets

const today = new Date();
---

<footer class="py-12 md:py-20 bg-gray-50 border-t border-gray-100 font-sans">
	<div class="max-w-5xl mx-auto px-6 text-center space-y-8">
		
		<!-- Logo Area -->
		<div class="flex justify-center">
			<a href="/" class="hover:opacity-80 transition-opacity">
				<Image 
					src={logoImg} 
					alt="Difabelzone Indonesia Logo" 
					class="h-12 md:h-16 w-auto grayscale opacity-70 hover:grayscale-0 hover:opacity-100 transition-all duration-500"
				/>
			</a>
		</div>

		<!-- Copyright & Info -->
		<div class="space-y-2">
			<p class="text-gray-900 font-bold text-lg tracking-tight">
				Difabelzone Indonesia
			</p>
			<p class="text-gray-500 text-sm font-medium leading-relaxed">
				&copy; {today.getFullYear()} All rights reserved. <br class="md:hidden"/> 
				Crafting Inclusivity from Yogyakarta.
			</p>
		</div>

		<!-- Social Links (Instagram & WhatsApp yang lebih relevan) -->
		<div class="flex justify-center gap-6">
			<!-- Instagram -->
			<a href="https://instagram.com/difabelzone.id" target="_blank" class="text-gray-400 hover:text-amber-700 transition-colors" aria-label="Follow us on Instagram">
				<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
					<path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
					<line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
				</svg>
			</a>

			<!-- WhatsApp -->
			<a href="https://wa.me/6281290098389" target="_blank" class="text-gray-400 hover:text-green-600 transition-colors" aria-label="Contact us on WhatsApp">
				<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.38 0 0 1 8 8v.5z"></path>
				</svg>
			</a>

			<!-- Email -->
			<a href="mailto:hello@difabelzone.id" class="text-gray-400 hover:text-amber-800 transition-colors" aria-label="Send us an email">
				<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
					<polyline points="22,6 12,13 2,6"></polyline>
				</svg>
			</a>
		</div>

		<!-- Tagline Small -->
		<div class="pt-8">
			<span class="text-[10px] font-black uppercase tracking-[0.3em] text-gray-300">
				Empowerment • Resilience • Heritage
			</span>
		</div>
	</div>
</footer>

<style>
	/* Mencegah link memiliki garis bawah */
	a {
		text-decoration: none;
	}
</style>